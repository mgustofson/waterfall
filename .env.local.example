# Supabase — get these from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — only used server-side (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — get your API key at resend.com
RESEND_API_KEY=re_your_key_here

# The email address you want reminders to come from
# Must be a verified sender in Resend
RESEND_FROM_EMAIL=reminders@yourdomain.com

# Your app's public URL (used to build links in emails)
# For local dev: http://localhost:3000
# For production: https://yourapp.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job secret — a random string you generate (e.g. openssl rand -hex 32)
# Add this same value to Vercel environment variables
CRON_SECRET=your-random-secret-here
